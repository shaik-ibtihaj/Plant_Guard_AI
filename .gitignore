# ──────────────────────────────────────────
# Machine Learning
# ──────────────────────────────────────────
# Model weights (large binary files — track with DVC or Git LFS)
models/checkpoints/*.pth
models/exported/
# Keep best_model.pth placeholder
!models/best_model.pth

# Datasets (do not commit raw/processed data)
datasets/raw/
datasets/processed/
# Keep metadata
!datasets/metadata/

# MLflow / W&B experiment logs
mlruns/
wandb/

